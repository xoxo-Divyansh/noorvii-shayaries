# MongoDB Connection
# Get from MongoDB Atlas: Clusters → Connect → Connect your application
# Use the connection string format with your credentials
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/noorvi_shayari?retryWrites=true&w=majority

# Database Name
MONGODB_DB=noorvi_shayari

# Admin Session Secret
# Generate using: node scripts/generate-secret.mjs
# Must be a long random string (64+ characters recommended)
ADMIN_SESSION_SECRET=your-secure-random-secret-here
